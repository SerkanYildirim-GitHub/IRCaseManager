@model IRCaseManager.ViewModels.CaseWorkspaceViewModel
@{
    var caseRecord = Model.Case;
    ViewData["Title"] = caseRecord.CaseId;
    var assignedUsers = caseRecord.Assignments
        .Where(assignment => assignment.ApplicationUser is not null)
        .Select(assignment => GetUserDisplayName(assignment.ApplicationUser))
        .OrderBy(displayName => displayName)
        .ToList();
    var canClose = Model.CanCloseCase;
    var canReopen = Model.CanReopenCase;
    var canEscalate = Model.CanEscalateCase;
    var canEditInvestigationDetails = Model.CanWorkCase && caseRecord.Status != CaseStatus.Closed;
    var evidenceSectionOpen = caseRecord.EvidenceItems.Count > 0 ||
        !string.IsNullOrWhiteSpace(Model.NewEvidence.Name) ||
        !string.IsNullOrWhiteSpace(Model.NewEvidence.EvidenceType);
    var timelineSectionOpen = !string.IsNullOrWhiteSpace(Model.NewTimelineEntry.Body);
    var closureSectionOpen = caseRecord.Status == CaseStatus.Closed;
    var playbookName = caseRecord.CaseType switch
    {
        CaseType.Phishing => caseRecord.CaseType.GetDisplayName(),
        CaseType.Malware => caseRecord.CaseType.GetDisplayName(),
        CaseType.UnauthorizedAccess => caseRecord.CaseType.GetDisplayName(),
        _ => "Generic"
    };
}

<section class="case-heading">
    <div>
        <p class="eyebrow">Case Workspace</p>
        <h2>@caseRecord.Title</h2>
        <div class="case-meta">
            <span class="badge severity-@caseRecord.Severity.ToString().ToLowerInvariant()">@caseRecord.Severity</span>
            <span class="badge status-@caseRecord.Status.ToString().ToLowerInvariant()">@caseRecord.Status</span>
            <span>@caseRecord.CaseType.GetDisplayName()</span>
        </div>
    </div>
    <div class="case-actions">
        @if (canEscalate && caseRecord.Status != CaseStatus.Closed)
        {
            <form asp-action="Escalate" asp-route-id="@caseRecord.CaseId" method="post">
                <button class="button button-secondary" type="submit">Escalate</button>
            </form>
        }
        @if (canClose && caseRecord.Status != CaseStatus.Closed)
        {
            <form asp-action="Close" asp-route-id="@caseRecord.CaseId" method="post">
                <button class="button" type="submit">Close Case</button>
            </form>
        }
        @if (canReopen && caseRecord.Status == CaseStatus.Closed)
        {
            <form asp-action="Reopen" asp-route-id="@caseRecord.CaseId" method="post">
                <button class="button" type="submit">Reopen Case</button>
            </form>
        }
        <a class="button button-secondary" asp-action="Index">Back to Cases</a>
    </div>
</section>

<section class="case-workspace-layout">
    <div class="workspace-main">
        <div class="workspace-section-controls" data-workspace-controls>
            <button class="button button-secondary button-compact" type="button" data-workspace-expand-all>Expand All</button>
            <button class="button button-secondary button-compact" type="button" data-workspace-collapse-all>Collapse All</button>
        </div>

        <details class="workspace-section workspace-details" id="overview" data-workspace-section open>
            <summary class="workspace-summary">
                <h2>Overview</h2>
            </summary>
            <div class="workspace-section-body">
            <dl class="overview-list">
                <dt>Case ID</dt>
                <dd>@caseRecord.CaseId</dd>
                <dt>Title</dt>
                <dd>@caseRecord.Title</dd>
                <dt>Severity</dt>
                <dd><span class="badge severity-@caseRecord.Severity.ToString().ToLowerInvariant()">@caseRecord.Severity</span></dd>
                <dt>Status</dt>
                <dd><span class="badge status-@caseRecord.Status.ToString().ToLowerInvariant()">@caseRecord.Status</span></dd>
                <dt>Case type</dt>
                <dd>@caseRecord.CaseType.GetDisplayName()</dd>
                <dt>Source reference</dt>
                <dd>@(caseRecord.SourceReference ?? "Not provided")</dd>
                <dt>Assigned to</dt>
                <dd>@(assignedUsers.Count == 0 ? "Unassigned" : string.Join(", ", assignedUsers))</dd>
                <dt>Queue</dt>
                <dd>@caseRecord.AssignedTeam</dd>
                <dt>Level</dt>
                <dd>@GetLevelDisplayName(caseRecord)</dd>
                <dt>Opened</dt>
                <dd>@caseRecord.OpenedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
                <dt>Closed</dt>
                <dd>@(caseRecord.ClosedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "Open")</dd>
                <dt>Created by</dt>
                <dd>@(caseRecord.CreatedBy?.UserName ?? "Unknown")</dd>
                <dt>Visibility</dt>
                <dd>@caseRecord.Visibility</dd>
            </dl>
            <div class="summary-block">
                <h3>Initial Summary</h3>
                <p>@caseRecord.InitialSummary</p>
            </div>
            </div>
        </details>

        <details class="workspace-section workspace-details" id="investigation-details" data-workspace-section open>
            <summary class="workspace-summary">
                <h2>Investigation Details</h2>
            </summary>
            <div class="workspace-section-body">
            @if (canEditInvestigationDetails)
            {
                <form class="investigation-form" asp-action="UpdateInvestigationDetails" asp-route-id="@caseRecord.CaseId" method="post">
                    <div asp-validation-summary="All" class="validation-summary" role="alert"></div>
                    <div class="form-grid">
                        <div class="field">
                            <label asp-for="InvestigationDetails.DetectionSource"></label>
                            <p class="field-help">Where the alert, report, or lead originated. Examples: EDR, SIEM, Email Gateway, User Report, Helpdesk, Network Alert, Threat Intelligence.</p>
                            <select asp-for="InvestigationDetails.DetectionSource" asp-items="Html.GetEnumSelectList<DetectionSource>()">
                                <option value="">Select source</option>
                            </select>
                            <span asp-validation-for="InvestigationDetails.DetectionSource"></span>
                        </div>
                        <div class="field">
                            <label asp-for="InvestigationDetails.AlertReportedAtUtc"></label>
                            <p class="field-help">When the suspicious activity was first reported or detected, not necessarily when the case was created.</p>
                            <input asp-for="InvestigationDetails.AlertReportedAtUtc" type="datetime-local" value="@FormatDateTimeLocal(Model.InvestigationDetails.AlertReportedAtUtc)" />
                            <span asp-validation-for="InvestigationDetails.AlertReportedAtUtc"></span>
                        </div>
                        <div class="field field-wide">
                            <label asp-for="InvestigationDetails.AffectedUsers"></label>
                            <p class="field-help">List known or suspected affected users. Include username, email, department, or role when useful.</p>
                            <textarea asp-for="InvestigationDetails.AffectedUsers" maxlength="4000" rows="4" placeholder="jsmith@example.com - Finance user who reported suspicious email&#10;unknown - investigation still in progress"></textarea>
                            <span asp-validation-for="InvestigationDetails.AffectedUsers"></span>
                        </div>
                        <div class="field field-wide">
                            <label asp-for="InvestigationDetails.AffectedAssets"></label>
                            <p class="field-help">List systems, hosts, cloud resources, IPs, or services involved.</p>
                            <textarea asp-for="InvestigationDetails.AffectedAssets" maxlength="4000" rows="4" placeholder="HOST-123 / 10.10.20.15 - suspected endpoint&#10;mailbox: jsmith@example.com&#10;VPN account: jsmith"></textarea>
                            <span asp-validation-for="InvestigationDetails.AffectedAssets"></span>
                        </div>
                        <div class="field field-wide">
                            <label asp-for="InvestigationDetails.InvolvedAppsOrTools"></label>
                            <p class="field-help">List business apps, security tools, or platforms involved in detection or response.</p>
                            <textarea asp-for="InvestigationDetails.InvolvedAppsOrTools" maxlength="4000" rows="4" placeholder="Microsoft 365, Defender for Endpoint, Sentinel, VPN, Okta"></textarea>
                            <span asp-validation-for="InvestigationDetails.InvolvedAppsOrTools"></span>
                        </div>
                        <div class="field field-wide">
                            <label asp-for="InvestigationDetails.InitialFindings"></label>
                            <p class="field-help">Summarize what is known so far. Include alert source, affected user/system, suspicious activity, and current assessment.</p>
                            <textarea asp-for="InvestigationDetails.InitialFindings" maxlength="4000" rows="5" placeholder="EDR alert reported suspicious PowerShell activity on HOST-123 for user jsmith. Initial review shows encoded command execution and outbound connection to an unknown IP. No confirmed data exfiltration at this time."></textarea>
                            <span asp-validation-for="InvestigationDetails.InitialFindings"></span>
                        </div>
                        <div class="field field-wide">
                            <label asp-for="InvestigationDetails.ContainmentActions"></label>
                            <p class="field-help">Document actions taken to stop or limit impact.</p>
                            <textarea asp-for="InvestigationDetails.ContainmentActions" maxlength="4000" rows="4" placeholder="Isolated HOST-123 in EDR.&#10;Disabled user jsmith account pending password reset.&#10;Blocked suspicious domain at email gateway.&#10;No additional affected hosts identified so far."></textarea>
                            <span asp-validation-for="InvestigationDetails.ContainmentActions"></span>
                        </div>
                        <div class="field field-wide">
                            <label asp-for="InvestigationDetails.IocSummary"></label>
                            <p class="field-help">Record indicators found during analysis. Include IPs, domains, hashes, file paths, sender addresses, URLs, or detection names.</p>
                            <textarea asp-for="InvestigationDetails.IocSummary" maxlength="4000" rows="4" placeholder="IP: 203.0.113.10&#10;Domain: suspicious-example.com&#10;File: invoice_update.exe&#10;Hash: hash if available&#10;Detection: Suspicious PowerShell"></textarea>
                            <span asp-validation-for="InvestigationDetails.IocSummary"></span>
                        </div>
                        <div class="field field-wide">
                            <label asp-for="InvestigationDetails.EscalationReason"></label>
                            <p class="field-help">Explain why this case requires higher-level review or another team.</p>
                            <textarea asp-for="InvestigationDetails.EscalationReason" maxlength="4000" rows="4" placeholder="Escalating because lateral movement is suspected and additional EDR/SIEM review is needed. L1 does not have sufficient access to validate domain controller authentication events."></textarea>
                            <span asp-validation-for="InvestigationDetails.EscalationReason"></span>
                        </div>
                        <div class="field field-wide">
                            <label asp-for="InvestigationDetails.ClosureSummary"></label>
                            <p class="field-help">Summarize outcome, containment/recovery, residual risk, and any follow-up.</p>
                            <textarea asp-for="InvestigationDetails.ClosureSummary" maxlength="4000" rows="4" placeholder="Incident contained. Affected endpoint isolated and reimaged. User password reset and MFA session revoked. No evidence of data exfiltration found. Follow-up: review PowerShell policy and add detection rule."></textarea>
                            <span asp-validation-for="InvestigationDetails.ClosureSummary"></span>
                        </div>
                    </div>
                    <div class="form-actions">
                        <button class="button" type="submit">Save Investigation Details</button>
                    </div>
                </form>
            }
            else
            {
                <dl class="investigation-details-list">
                    <dt>Detection source</dt>
                    <dd>@FormatDetectionSource(caseRecord.DetectionSource)</dd>
                    <dt>Alert/report time</dt>
                    <dd>@FormatDateTime(caseRecord.AlertReportedAtUtc)</dd>
                    <dt>Affected user(s)</dt>
                    <dd>@FormatOptional(caseRecord.AffectedUsers)</dd>
                    <dt>Affected asset(s)</dt>
                    <dd>@FormatOptional(caseRecord.AffectedAssets)</dd>
                    <dt>Involved app(s) or tool(s)</dt>
                    <dd>@FormatOptional(caseRecord.InvolvedAppsOrTools)</dd>
                    <dt>Initial findings</dt>
                    <dd>@FormatOptional(caseRecord.InitialFindings)</dd>
                    <dt>Containment actions</dt>
                    <dd>@FormatOptional(caseRecord.ContainmentActions)</dd>
                    <dt>IOC summary</dt>
                    <dd>@FormatOptional(caseRecord.IocSummary)</dd>
                    <dt>Escalation reason</dt>
                    <dd>@FormatOptional(caseRecord.EscalationReason)</dd>
                    <dt>Closure summary</dt>
                    <dd>@FormatOptional(caseRecord.ClosureSummary)</dd>
                </dl>
            }
            </div>
        </details>

        <details class="workspace-section workspace-details" id="assignment-history" data-workspace-section>
            <summary class="workspace-summary">
                <h2>Assignment History</h2>
            </summary>
            <div class="workspace-section-body">
            @if (caseRecord.AssignmentHistory.Count == 0)
            {
                <p class="empty-state">No assignment or escalation history has been recorded yet.</p>
            }
            else
            {
                <div class="assignment-history-list">
                    @foreach (var history in caseRecord.AssignmentHistory.OrderByDescending(item => item.OccurredUtc))
                    {
                        <article class="assignment-history-item">
                            <div>
                                <strong>@history.ActionType</strong>
                                <span>@history.OccurredUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                            </div>
                            <dl>
                                <dt>From</dt>
                                <dd>@FormatAssignmentParty(history.FromUser, history.FromTeam)</dd>
                                <dt>To</dt>
                                <dd>@FormatAssignmentParty(history.ToUser, history.ToTeam)</dd>
                                <dt>Performed by</dt>
                                <dd>@GetUserDisplayName(history.PerformedByUser)</dd>
                                <dt>Note</dt>
                                <dd>@(string.IsNullOrWhiteSpace(history.Reason) ? "Not provided" : history.Reason)</dd>
                            </dl>
                        </article>
                    }
                </div>
            }
            </div>
        </details>

        <details class="workspace-section workspace-details" id="evidence" data-workspace-section open="@evidenceSectionOpen">
            <summary class="workspace-summary">
                <h2>Evidence Metadata</h2>
            </summary>
            <div class="workspace-section-body">
            <p class="muted">File attachment will be added in a later secure upload slice.</p>
            @if (caseRecord.EvidenceItems.Count == 0)
            {
                <p class="empty-state">No evidence metadata has been documented yet.</p>
            }
            else
            {
                <div class="evidence-list">
                    @foreach (var evidence in caseRecord.EvidenceItems.OrderByDescending(item => item.CollectedAt))
                    {
                        <article class="evidence-item">
                            <div>
                                <strong>@evidence.Name</strong>
                                <span>@evidence.EvidenceType</span>
                            </div>
                            <dl>
                                <dt>Source</dt>
                                <dd>@(string.IsNullOrWhiteSpace(evidence.Source) ? "Not provided" : evidence.Source)</dd>
                                <dt>Collected</dt>
                                <dd>@evidence.CollectedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</dd>
                                <dt>Description</dt>
                                <dd>@(string.IsNullOrWhiteSpace(evidence.Description) ? "Not provided" : evidence.Description)</dd>
                                <dt>Analyst notes</dt>
                                <dd>@(string.IsNullOrWhiteSpace(evidence.AnalystNotes) ? "Not provided" : evidence.AnalystNotes)</dd>
                            </dl>
                        </article>
                    }
                </div>
            }

            @if (Model.CanWorkCase)
            {
                <form class="evidence-form" asp-action="AddEvidence" asp-route-id="@caseRecord.CaseId" method="post">
                    <h3>Add Evidence Metadata</h3>
                    <div asp-validation-summary="All" class="validation-summary" role="alert"></div>
                    <div class="form-grid">
                        <div class="field">
                            <label asp-for="NewEvidence.EvidenceType"></label>
                            <input name="EvidenceType" value="@Model.NewEvidence.EvidenceType" maxlength="80" autocomplete="off" />
                        </div>
                        <div class="field">
                            <label asp-for="NewEvidence.Name"></label>
                            <input name="Name" value="@Model.NewEvidence.Name" maxlength="160" autocomplete="off" />
                        </div>
                        <div class="field">
                            <label asp-for="NewEvidence.Source"></label>
                            <input name="Source" value="@Model.NewEvidence.Source" maxlength="256" autocomplete="off" />
                        </div>
                        <div class="field">
                            <label asp-for="NewEvidence.CollectedAt"></label>
                            <input id="NewEvidence_CollectedAt" name="CollectedAt" type="datetime-local" step="60" value="@FormatDateTimeLocal(Model.NewEvidence.CollectedAt)" autocomplete="off" />
                        </div>
                        <div class="field field-wide">
                            <label asp-for="NewEvidence.Description"></label>
                            <textarea name="Description" maxlength="2000" rows="4">@Model.NewEvidence.Description</textarea>
                        </div>
                        <div class="field field-wide">
                            <label asp-for="NewEvidence.AnalystNotes"></label>
                            <textarea name="AnalystNotes" maxlength="2000" rows="4">@Model.NewEvidence.AnalystNotes</textarea>
                        </div>
                    </div>
                    <div class="form-actions">
                        <button class="button" type="submit">Add Evidence</button>
                    </div>
                </form>
            }
            </div>
        </details>

        <details class="workspace-section workspace-details" id="timeline" data-workspace-section open="@timelineSectionOpen">
            <summary class="workspace-summary">
                <h2>Timeline / Investigation Log</h2>
            </summary>
            <div class="workspace-section-body">
            @if (caseRecord.TimelineEntries.Count == 0)
            {
                <p class="empty-state">No timeline entries have been documented yet.</p>
            }
            else
            {
                <div class="timeline-entry-list">
                    @foreach (var entry in caseRecord.TimelineEntries.OrderByDescending(item => item.EventTime))
                    {
                        <article class="timeline-entry-item">
                            <div>
                                <strong>@entry.Title</strong>
                                <span>@entry.EventTime.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</span>
                            </div>
                            <p>@entry.Description</p>
                            <span class="muted">By @GetUserDisplayName(entry.CreatedBy)</span>
                        </article>
                    }
                </div>
            }

            @if (Model.CanWorkCase)
            {
                <form class="timeline-form" asp-action="AddTimelineEntry" asp-route-id="@caseRecord.CaseId" method="post">
                    <h3>Add Timeline Entry</h3>
                    <div asp-validation-summary="All" class="validation-summary" role="alert"></div>
                    <div class="form-grid">
                        <div class="field">
                            <label asp-for="NewTimelineEntry.ActivityType"></label>
                            <p class="field-help">Choose the type that best describes the entry.</p>
                            <select asp-for="NewTimelineEntry.ActivityType">
                                <option value="">Select activity type</option>
                                @foreach (var activityType in IRCaseManager.ViewModels.TimelineEntryViewModel.ActivityTypes)
                                {
                                    <option value="@activityType">@activityType</option>
                                }
                            </select>
                            <span asp-validation-for="NewTimelineEntry.ActivityType"></span>
                        </div>
                        <div class="field field-wide">
                            <label asp-for="NewTimelineEntry.Body"></label>
                            <p class="field-help">Write what was done, observed, decided, or communicated. Avoid passwords, secrets, or unnecessary sensitive data.</p>
                            <textarea asp-for="NewTimelineEntry.Body" maxlength="2000" rows="5" placeholder="Reviewed EDR alert for HOST-123. Confirmed suspicious PowerShell execution. Collected process tree and network connection details. Next step: review authentication logs for the affected user."></textarea>
                            <span asp-validation-for="NewTimelineEntry.Body"></span>
                        </div>
                    </div>
                    <div class="form-actions">
                        <button class="button" type="submit">Add Entry</button>
                    </div>
                </form>
            }
            </div>
        </details>

        <details class="workspace-section workspace-details" id="findings" data-workspace-section>
            <summary class="workspace-summary">
                <h2>Findings / IOCs</h2>
            </summary>
            <div class="workspace-section-body">
            <p class="empty-state">No findings, observables, or indicators have been documented yet.</p>
            </div>
        </details>

        <details class="workspace-section workspace-details" id="mitre" data-workspace-section>
            <summary class="workspace-summary">
                <h2>MITRE ATT&amp;CK Mapping</h2>
            </summary>
            <div class="workspace-section-body">
            <p class="empty-state">Observed tactics, techniques, and procedures will be documented here as the investigation develops.</p>
            </div>
        </details>

        <details class="workspace-section workspace-details" id="notes" data-workspace-section>
            <summary class="workspace-summary">
                <h2>Notes / Actions</h2>
            </summary>
            <div class="workspace-section-body">
            <p class="empty-state">No analyst notes or response actions have been documented yet.</p>
            </div>
        </details>

        <details class="workspace-section workspace-details" id="closure" data-workspace-section open="@closureSectionOpen">
            <summary class="workspace-summary">
                <h2>Closure Report</h2>
            </summary>
            <div class="workspace-section-body">
            <p class="empty-state">The closure report will be generated from documented case data once the case is ready to close.</p>
            </div>
        </details>
    </div>

    <aside class="playbook-sidebar" id="playbook">
        <div class="panel-header">
            <div>
                <p class="eyebrow">@caseRecord.CaseType.GetDisplayName()</p>
                <h2>IR Playbook: @playbookName</h2>
            </div>
        </div>
        <div class="playbook-steps">
            @foreach (var step in Model.PlaybookSteps)
            {
                var canToggleStep = Model.CanWorkCase && step.CanManuallyToggle;
                <details class="playbook-step @(step.IsComplete ? "is-complete playbook-step--complete" : "is-open playbook-step--incomplete") @(step.IsAutoCompleted ? "is-auto-complete" : string.Empty)" open="@(!step.IsComplete)">
                    <summary class="playbook-step-summary">
                        <span class="playbook-status-indicator" aria-hidden="true"></span>
                        <span class="playbook-step-title">@step.Title</span>
                        @if (step.IsAutoCompleted)
                        {
                            <span class="playbook-auto-badge" title="@step.AutoCompletionReason">Auto</span>
                        }
                    </summary>
                    <div class="playbook-step-body">
                        <p>@step.Description</p>
                        @if (step.IsAutoCompleted)
                        {
                            <p class="playbook-auto-note">@step.AutoCompletionReason</p>
                        }
                        @if (step.IsAutoManaged)
                        {
                            @if (!step.IsAutoCompleted)
                            {
                                <span class="muted">Complete the related investigation field.</span>
                            }
                        }
                        else if (canToggleStep)
                        {
                            <form class="playbook-step-form" asp-action="TogglePlaybookStep" asp-route-id="@caseRecord.CaseId" method="post">
                                <input type="hidden" name="stepKey" value="@step.Key" />
                                <input type="hidden" name="completionState" value="@(step.IsManuallyCompleted ? "open" : "complete")" />
                                <label class="playbook-step-toggle">
                                    <input type="checkbox" checked="@step.IsManuallyCompleted" onchange="this.form.submit()" />
                                    <span>@(step.IsManuallyCompleted ? "Marked complete" : "Mark step complete")</span>
                                </label>
                            </form>
                        }
                        else if (!Model.CanWorkCase)
                        {
                            <span class="muted">Read-only</span>
                        }
                    </div>
                </details>
            }
        </div>
    </aside>
</section>

@section Scripts {
    <script>
        (() => {
            const controls = document.querySelector("[data-workspace-controls]");
            if (!controls) {
                return;
            }

            const sections = Array.from(document.querySelectorAll("[data-workspace-section]"));
            controls.querySelector("[data-workspace-expand-all]")?.addEventListener("click", () => {
                sections.forEach(section => {
                    section.open = true;
                });
            });
            controls.querySelector("[data-workspace-collapse-all]")?.addEventListener("click", () => {
                sections.forEach(section => {
                    section.open = false;
                });
            });
        })();
    </script>
}

@functions {
    private static string GetUserDisplayName(ApplicationUser? user)
    {
        return string.IsNullOrWhiteSpace(user?.UserName) ? "Unassigned" : user.UserName;
    }

    private static string GetLevelDisplayName(Case irCase)
    {
        var assignedUser = irCase.Assignments
            .OrderByDescending(assignment => assignment.AssignedAt)
            .Select(assignment => assignment.ApplicationUser)
            .FirstOrDefault(applicationUser => applicationUser is not null);

        return assignedUser?.Role?.Name switch
        {
            RoleNames.AnalystLevel1 => "L1",
            RoleNames.AnalystLevel2 => "L2",
            RoleNames.Admin => "Admin",
            _ => "None"
        };
    }

    private static string FormatAssignmentParty(ApplicationUser? user, string? queue)
    {
        var userDisplay = GetUserDisplayName(user);
        if (string.IsNullOrWhiteSpace(queue))
        {
            return userDisplay;
        }

        return userDisplay == "Unassigned" ? queue : $"{userDisplay} / {queue}";
    }

    private static string FormatDetectionSource(DetectionSource? detectionSource)
    {
        return detectionSource?.GetDisplayName() ?? "Not provided";
    }

    private static string FormatDateTime(DateTimeOffset? value)
    {
        return value?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "Not provided";
    }

    private static string FormatDateTimeLocal(DateTimeOffset? value)
    {
        return value?.ToLocalTime().ToString("yyyy-MM-ddTHH:mm") ?? string.Empty;
    }

    private static string FormatOptional(string? value)
    {
        return string.IsNullOrWhiteSpace(value) ? "Not provided" : value;
    }
}
