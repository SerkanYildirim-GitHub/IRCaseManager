@model IRCaseManager.ViewModels.CaseAnalyticsViewModel
@{
    ViewData["Title"] = "Case Analytics";
}

<section class="analytics-heading">
    <div class="analytics-heading-copy">
        <p class="eyebrow">Metrics</p>
        <h2>Case Analytics</h2>
        <p class="muted">Case activity and distribution for the selected time range.</p>
    </div>
    <form class="analytics-range-form" asp-action="Analytics" method="get" data-analytics-range-form>
        <div class="field">
            <label for="analytics-range">Range</label>
            <select id="analytics-range" name="range" data-analytics-range-select>
                <option value="24h" selected="@(Model.SelectedRange == "24h")">Last 24 Hours</option>
                <option value="7d" selected="@(Model.SelectedRange == "7d")">Last 7 Days</option>
                <option value="30d" selected="@(Model.SelectedRange == "30d")">Last 30 Days</option>
                <option value="custom" selected="@(Model.SelectedRange == "custom")">Custom Range</option>
            </select>
        </div>
        <div class="field">
            <label for="analytics-chart">Chart</label>
            <select id="analytics-chart" name="chart" data-analytics-chart-select>
                <option value="donut" selected="@(Model.ChartMode == "donut")">Donut</option>
                <option value="bar" selected="@(Model.ChartMode == "bar")">Bar</option>
                <option value="table" selected="@(Model.ChartMode == "table")">Table</option>
            </select>
        </div>
        <div class="field analytics-custom-date-field" data-analytics-custom-date-field hidden="@(Model.SelectedRange != "custom")">
            <label for="analytics-from">From</label>
            <input id="analytics-from" name="from" type="date" value="@Model.FromInput" />
        </div>
        <div class="field analytics-custom-date-field" data-analytics-custom-date-field hidden="@(Model.SelectedRange != "custom")">
            <label for="analytics-to">To</label>
            <input id="analytics-to" name="to" type="date" value="@Model.ToInput" />
        </div>
        <button class="button analytics-custom-apply" type="submit" data-analytics-custom-apply hidden="@(Model.SelectedRange != "custom")">Apply</button>
    </form>
    @{
        var trendBuckets = Model.CreatedOverTime;
        var trendLabelInterval = GetTrendLabelInterval(trendBuckets.Count);
    }
    <div class="analytics-heading-trend" aria-label="Case intake trend">
        @if (!trendBuckets.Any(item => item.Count > 0))
        {
            <p class="empty-state">No cases opened in this range.</p>
        }
        else
        {
            <div class="intake-trend-chart" role="img" aria-label="Case intake count by time bucket">
                <div class="intake-trend-grid" aria-hidden="true"></div>
                <div class="intake-trend-bars">
                    @for (var bucketIndex = 0; bucketIndex < trendBuckets.Count; bucketIndex++)
                    {
                        var item = trendBuckets[bucketIndex];
                        var title = $"{item.Label}: {item.Count} {(item.Count == 1 ? "case" : "cases")}";
                        var showLabel = ShouldShowTrendLabel(bucketIndex, trendBuckets.Count, trendLabelInterval);
                        <span class="intake-trend-bucket" title="@title" aria-label="@title">
                            <span class="intake-trend-bar @item.ColorClass"
                                  style="--trend-height: @item.BarPercent%; --bar-color: @item.Color;"></span>
                            <span class="intake-trend-label @(showLabel ? string.Empty : "intake-trend-label-hidden")">@item.Label</span>
                        </span>
                    }
                </div>
            </div>
        }
    </div>
</section>

@if (!string.IsNullOrWhiteSpace(Model.ValidationMessage))
{
    <div class="notice" role="status">@Model.ValidationMessage</div>
}

@if (!Model.HasCases)
{
    <p class="empty-state">No cases found for this time range.</p>
}

<section class="metric-grid analytics-summary-grid" aria-label="Case analytics summary">
    <article class="metric metric-neutral">
        <span>Total cases</span>
        <strong>@Model.TotalCases</strong>
    </article>
    <article class="metric status-assigned">
        <span>Open cases</span>
        <strong>@Model.OpenCases</strong>
    </article>
    <article class="metric status-closed">
        <span>Closed cases</span>
        <strong>@Model.ClosedCases</strong>
    </article>
    <article class="metric status-escalated">
        <span>Escalated cases</span>
        <strong>@Model.EscalatedCases</strong>
    </article>
    <article class="metric severity-critical">
        <span>Critical cases</span>
        <strong>@Model.CriticalCases</strong>
    </article>
    <article class="metric severity-high">
        <span>High cases</span>
        <strong>@Model.HighCases</strong>
    </article>
</section>

<section class="analytics-grid">
    @for (var breakdownIndex = 0; breakdownIndex < Model.BreakdownSections.Count; breakdownIndex++)
    {
        var breakdown = Model.BreakdownSections[breakdownIndex];
        var chartId = $"analytics-chart-{breakdownIndex}";
        <article class="panel analytics-panel" data-analytics-chart-card tabindex="0" aria-label="@($"Open {breakdown.Title} chart larger")">
            <div class="analytics-panel-header">
                <div>
                    <h2>@breakdown.Title</h2>
                    <p class="muted">@breakdown.Description</p>
                </div>
            </div>
            <div class="analytics-card-content" data-analytics-card-content data-analytics-chart-scope>
                @if (!breakdown.HasData)
                {
                    <p class="empty-state">No cases found for this breakdown.</p>
                }
                else if (Model.ChartMode == "donut")
                {
                    <div class="analytics-donut-layout">
                        <div class="donut-svg-wrap">
                            <svg class="donut-svg" viewBox="0 0 100 100" role="img" aria-label="@breakdown.Title">
                                <circle class="donut-base" cx="50" cy="50" r="40"></circle>
                                @for (var itemIndex = 0; itemIndex < breakdown.Items.Count; itemIndex++)
                                {
                                    var item = breakdown.Items[itemIndex];
                                    var segmentKey = $"{chartId}-{itemIndex}";
                                    if (item.Count > 0)
                                    {
                                        <circle class="donut-segment @item.ColorClass"
                                                cx="50"
                                                cy="50"
                                                r="40"
                                                pathLength="100"
                                                stroke-dasharray="@item.SegmentLength 100"
                                                stroke-dashoffset="-@item.SegmentStart"
                                                style="--segment-color: @item.Color;"
                                                transform="rotate(-90 50 50)"
                                                tabindex="0"
                                                role="button"
                                                data-segment-key="@segmentKey"
                                                aria-label="@($"{item.Label}: {item.Count} cases, {item.Percent}%")"></circle>
                                    }
                                }
                            </svg>
                            <div class="donut-chart-inner">
                                <strong>@breakdown.Total</strong>
                                <span>Total</span>
                            </div>
                        </div>
                        <div class="chart-legend">
                            @for (var itemIndex = 0; itemIndex < breakdown.Items.Count; itemIndex++)
                            {
                                var item = breakdown.Items[itemIndex];
                                var segmentKey = $"{chartId}-{itemIndex}";
                                <button class="legend-row" type="button" data-segment-key="@segmentKey">
                                    <span class="legend-swatch @item.ColorClass" style="--item-color: @item.Color;"></span>
                                    <span>@item.Label</span>
                                    <strong>@item.Count</strong>
                                    <span>@item.Percent%</span>
                                </button>
                            }
                        </div>
                    </div>
                }
                else if (Model.ChartMode == "bar")
                {
                    <div class="bar-list">
                        @foreach (var item in breakdown.Items)
                        {
                            <div class="bar-row">
                                <div class="bar-row-label">
                                    <span>@item.Label</span>
                                    <strong>@item.Count (@item.Percent%)</strong>
                                </div>
                                <div class="bar-track" aria-hidden="true">
                                    <span class="bar-fill @item.ColorClass" style="--bar-percent: @item.BarPercent%; --bar-color: @item.Color;"></span>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <table class="analytics-table">
                        <thead>
                            <tr>
                                <th>Label</th>
                                <th>Count</th>
                                <th>Percent</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in breakdown.Items)
                            {
                                <tr>
                                    <td><span class="legend-swatch @item.ColorClass" style="--item-color: @item.Color;"></span>@item.Label</td>
                                    <td>@item.Count</td>
                                    <td>@item.Percent%</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </article>
    }
</section>

<div class="analytics-modal" data-analytics-chart-modal hidden>
    <div class="analytics-modal-backdrop" data-analytics-modal-close></div>
    <section class="analytics-modal-dialog" role="dialog" aria-modal="true" aria-labelledby="analytics-modal-title" tabindex="-1">
        <div class="analytics-modal-header">
            <div>
                <h2 id="analytics-modal-title" data-analytics-modal-title>Chart</h2>
                <p class="muted" data-analytics-modal-description></p>
            </div>
        </div>
        <div class="analytics-modal-content" data-analytics-modal-content></div>
    </section>
</div>

@functions {
    private static int GetTrendLabelInterval(int bucketCount)
    {
        if (bucketCount <= 8)
        {
            return 1;
        }

        if (bucketCount <= 24)
        {
            return 3;
        }

        if (bucketCount <= 31)
        {
            return 5;
        }

        return Math.Max(1, (int)Math.Ceiling(bucketCount / 6.0));
    }

    private static bool ShouldShowTrendLabel(int index, int bucketCount, int interval)
    {
        return index == 0 ||
            index == bucketCount - 1 ||
            (interval > 0 && index % interval == 0);
    }
}
