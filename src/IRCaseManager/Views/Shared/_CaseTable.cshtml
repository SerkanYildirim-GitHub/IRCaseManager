@model IReadOnlyList<Case>
@{
    var isAdmin = User.IsInRole(RoleNames.Admin);
    var isAnalyst = User.IsInRole(RoleNames.AnalystLevel1) || User.IsInRole(RoleNames.AnalystLevel2);
    var caseTypes = Model.Select(irCase => irCase.CaseType.GetDisplayName()).Distinct().OrderBy(value => value).ToList();
    var severities = Model.Select(irCase => irCase.Severity.ToString()).Distinct().OrderBy(value => value).ToList();
    var assignedToValues = Model.Select(GetAssignedToDisplayName).Distinct().OrderBy(value => value).ToList();
    var statuses = Model.Select(irCase => irCase.Status.ToString()).Distinct().OrderBy(value => value).ToList();
}

<div class="table-wrap">
    <table class="case-table" data-case-filter-table>
        <thead>
            <tr>
                <th>
                    <div class="header-filter" data-case-filter-shell>
                        <button class="header-filter-button" type="button" aria-haspopup="dialog" aria-expanded="false" data-case-filter-toggle>
                            <span>Date</span><span class="header-filter-caret" aria-hidden="true"></span>
                        </button>
                        <div class="header-filter-menu" hidden data-case-filter-menu>
                            <label class="sr-only" for="case-filter-date">Filter by date</label>
                            <input id="case-filter-date" type="search" data-case-filter="date" aria-label="Filter by date" />
                        </div>
                    </div>
                </th>
                <th>
                    <div class="header-filter" data-case-filter-shell>
                        <button class="header-filter-button" type="button" aria-haspopup="dialog" aria-expanded="false" data-case-filter-toggle>
                            <span>Case ID</span><span class="header-filter-caret" aria-hidden="true"></span>
                        </button>
                        <div class="header-filter-menu" hidden data-case-filter-menu>
                            <label class="sr-only" for="case-filter-id">Filter by Case ID</label>
                            <input id="case-filter-id" type="search" data-case-filter="case-id" aria-label="Filter by Case ID" />
                        </div>
                    </div>
                </th>
                <th>
                    <div class="header-filter" data-case-filter-shell>
                        <button class="header-filter-button" type="button" aria-haspopup="dialog" aria-expanded="false" data-case-filter-toggle>
                            <span>Title</span><span class="header-filter-caret" aria-hidden="true"></span>
                        </button>
                        <div class="header-filter-menu" hidden data-case-filter-menu>
                            <label class="sr-only" for="case-filter-title">Filter by title</label>
                            <input id="case-filter-title" type="search" data-case-filter="title" aria-label="Filter by title" />
                        </div>
                    </div>
                </th>
                <th>
                    <div class="header-filter" data-case-filter-shell>
                        <button class="header-filter-button" type="button" aria-haspopup="dialog" aria-expanded="false" data-case-filter-toggle>
                            <span>Type</span><span class="header-filter-caret" aria-hidden="true"></span>
                        </button>
                        <div class="header-filter-menu" hidden data-case-filter-menu>
                            <label class="sr-only" for="case-filter-type">Filter by type</label>
                            <select id="case-filter-type" data-case-filter="type" aria-label="Filter by type">
                                <option value="">All</option>
                                @foreach (var caseType in caseTypes)
                                {
                                    <option value="@caseType">@caseType</option>
                                }
                            </select>
                        </div>
                    </div>
                </th>
                <th>
                    <div class="header-filter" data-case-filter-shell>
                        <button class="header-filter-button" type="button" aria-haspopup="dialog" aria-expanded="false" data-case-filter-toggle>
                            <span>Severity</span><span class="header-filter-caret" aria-hidden="true"></span>
                        </button>
                        <div class="header-filter-menu" hidden data-case-filter-menu>
                            <label class="sr-only" for="case-filter-severity">Filter by severity</label>
                            <select id="case-filter-severity" data-case-filter="severity" aria-label="Filter by severity">
                                <option value="">All</option>
                                @foreach (var severity in severities)
                                {
                                    <option value="@severity">@severity</option>
                                }
                            </select>
                        </div>
                    </div>
                </th>
                <th>
                    <div class="header-filter" data-case-filter-shell>
                        <button class="header-filter-button" type="button" aria-haspopup="dialog" aria-expanded="false" data-case-filter-toggle>
                            <span>Assigned to</span><span class="header-filter-caret" aria-hidden="true"></span>
                        </button>
                        <div class="header-filter-menu" hidden data-case-filter-menu>
                            <label class="sr-only" for="case-filter-assigned">Filter by assigned analyst</label>
                            <select id="case-filter-assigned" data-case-filter="assigned-to" aria-label="Filter by assigned analyst">
                                <option value="">All</option>
                                @foreach (var assignedTo in assignedToValues)
                                {
                                    <option value="@assignedTo">@assignedTo</option>
                                }
                            </select>
                        </div>
                    </div>
                </th>
                <th>
                    <div class="header-filter" data-case-filter-shell>
                        <button class="header-filter-button" type="button" aria-haspopup="dialog" aria-expanded="false" data-case-filter-toggle>
                            <span>Team</span><span class="header-filter-caret" aria-hidden="true"></span>
                        </button>
                        <div class="header-filter-menu" hidden data-case-filter-menu>
                            <label class="sr-only" for="case-filter-team">Filter by team</label>
                            <input id="case-filter-team" type="search" data-case-filter="team" aria-label="Filter by team" />
                        </div>
                    </div>
                </th>
                <th>
                    <div class="header-filter" data-case-filter-shell>
                        <button class="header-filter-button" type="button" aria-haspopup="dialog" aria-expanded="false" data-case-filter-toggle>
                            <span>Status</span><span class="header-filter-caret" aria-hidden="true"></span>
                        </button>
                        <div class="header-filter-menu" hidden data-case-filter-menu>
                            <label class="sr-only" for="case-filter-status">Filter by status</label>
                            <select id="case-filter-status" data-case-filter="status" aria-label="Filter by status">
                                <option value="">All</option>
                                @foreach (var status in statuses)
                                {
                                    <option value="@status">@status</option>
                                }
                            </select>
                        </div>
                    </div>
                </th>
                <th>Edit</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var irCase in Model)
            {
                var openedDate = irCase.OpenedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
                var caseType = irCase.CaseType.GetDisplayName();
                var assignedTo = GetAssignedToDisplayName(irCase);
                <tr data-case-row
                    data-filter-date="@openedDate"
                    data-filter-case-id="@irCase.CaseId"
                    data-filter-title="@irCase.Title"
                    data-filter-type="@caseType"
                    data-filter-severity="@irCase.Severity"
                    data-filter-assigned-to="@assignedTo"
                    data-filter-team="@irCase.AssignedTeam"
                    data-filter-status="@irCase.Status">
                    <td>@openedDate</td>
                    <td>
                        <a class="case-link" asp-controller="Cases" asp-action="Details" asp-route-id="@irCase.CaseId">
                            <strong>@irCase.CaseId</strong>
                        </a>
                    </td>
                    <td>
                        <a class="case-link" asp-controller="Cases" asp-action="Details" asp-route-id="@irCase.CaseId">
                            @irCase.Title
                        </a>
                    </td>
                    <td>@caseType</td>
                    <td><span class="badge severity-@irCase.Severity.ToString().ToLowerInvariant()">@irCase.Severity</span></td>
                    <td>@assignedTo</td>
                    <td>@irCase.AssignedTeam</td>
                    <td><span class="badge status-@irCase.Status.ToString().ToLowerInvariant()">@irCase.Status</span></td>
                    <td>
                        @if (CanEditRow(irCase, isAdmin, isAnalyst))
                        {
                            <a class="button button-compact" asp-controller="Cases" asp-action="Edit" asp-route-id="@irCase.CaseId">Edit</a>
                        }
                        else if (isAnalyst && irCase.Status == CaseStatus.Closed)
                        {
                            <button class="button button-compact" type="button" disabled title="Closed cases are read-only">Edit</button>
                        }
                        else
                        {
                            <span class="muted">Read-only</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>
    <p class="empty-state case-filter-empty" data-case-filter-empty hidden>No cases match the current filters.</p>
</div>

@functions {
    private static string GetAssignedToDisplayName(Case irCase)
    {
        var assignedUserName = irCase.Assignments
            .Select(assignment => assignment.ApplicationUser?.UserName)
            .FirstOrDefault(userName => !string.IsNullOrWhiteSpace(userName));

        return assignedUserName switch
        {
            null => "Unassigned",
            "analyst.l1.local" => RoleNames.AnalystLevel1,
            "analyst.l2.local" => RoleNames.AnalystLevel2,
            _ => assignedUserName
        };
    }

    private static bool CanEditRow(Case irCase, bool isAdmin, bool isAnalyst)
    {
        return isAdmin || (isAnalyst && irCase.Status != CaseStatus.Closed);
    }

}
