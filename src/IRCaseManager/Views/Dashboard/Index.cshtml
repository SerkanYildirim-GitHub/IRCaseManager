@model IReadOnlyList<Case>
@{
    ViewData["Title"] = "Dashboard";
}

<section class="metric-grid" aria-label="Case metrics">
    <article class="metric severity-critical">
        <span>Critical</span>
        <strong>@ViewBag.CriticalCases</strong>
    </article>
    <article class="metric severity-high">
        <span>High</span>
        <strong>@ViewBag.HighCases</strong>
    </article>
    <article class="metric severity-medium">
        <span>Medium</span>
        <strong>@ViewBag.MediumCases</strong>
    </article>
    <article class="metric severity-low">
        <span>Low</span>
        <strong>@ViewBag.LowCases</strong>
    </article>
    <article class="metric severity-informational">
        <span>Informational</span>
        <strong>@ViewBag.InformationalCases</strong>
    </article>
    <a class="metric metric-neutral metric-total metric-link" asp-controller="Cases" asp-action="Analytics" aria-label="Open case analytics">
        <span>Total Cases</span>
        <div class="metric-total-body">
            <strong>@ViewBag.TotalCases</strong>
            <div class="metric-breakdown" aria-label="Status breakdown">
                <span>New</span><strong>@ViewBag.NewCases</strong>
                <span>Assigned</span><strong>@ViewBag.AssignedCases</strong>
                <span>Escalated</span><strong>@ViewBag.EscalatedCases</strong>
                <span>Closed</span><strong>@ViewBag.ClosedCases</strong>
            </div>
        </div>
    </a>
</section>

<section class="panel">
    <div class="panel-header">
        <h2>Recent Cases</h2>
        <a class="button" asp-controller="Cases" asp-action="Create">Create New Case</a>
    </div>
    @if (Model.Count == 0)
    {
        <p class="muted">No cases have been created yet.</p>
    }
    else
    {
        <partial name="_RecentCaseTable" model="Model" />
    }
</section>
