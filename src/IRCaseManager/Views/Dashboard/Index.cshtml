@model IReadOnlyList<Case>
@{
    ViewData["Title"] = "Dashboard";
}

<section class="metric-grid" aria-label="Case metrics">
    <article class="metric metric-neutral">
        <span>Total</span>
        <strong>@ViewBag.TotalCases</strong>
    </article>
    <article class="metric status-new">
        <span>New</span>
        <strong>@ViewBag.NewCases</strong>
    </article>
    <article class="metric status-assigned">
        <span>Assigned / Open</span>
        <strong>@ViewBag.AssignedCases</strong>
    </article>
    <article class="metric status-escalated">
        <span>Escalated</span>
        <strong>@ViewBag.EscalatedCases</strong>
    </article>
    <article class="metric metric-waiting">
        <span>Waiting</span>
        <strong>@ViewBag.WaitingCases</strong>
    </article>
    <article class="metric metric-closed">
        <span>Closed</span>
        <strong>@ViewBag.ClosedCases</strong>
    </article>
</section>

<section class="metric-grid severity-grid" aria-label="Severity metrics">
    <article class="metric severity-critical">
        <span>Critical</span>
        <strong>@ViewBag.CriticalCases</strong>
    </article>
    <article class="metric severity-high">
        <span>High</span>
        <strong>@ViewBag.HighCases</strong>
    </article>
    <article class="metric severity-medium">
        <span>Medium</span>
        <strong>@ViewBag.MediumCases</strong>
    </article>
    <article class="metric severity-low">
        <span>Low</span>
        <strong>@ViewBag.LowCases</strong>
    </article>
    @if ((int)ViewBag.InformationalCases > 0)
    {
        <article class="metric severity-informational">
            <span>Informational</span>
            <strong>@ViewBag.InformationalCases</strong>
        </article>
    }
</section>

<section class="panel">
    <div class="panel-header">
        <h2>Recent Cases</h2>
        <a class="button" asp-controller="Cases" asp-action="Create">Create New Case</a>
    </div>
    @if (Model.Count == 0)
    {
        <p class="muted">No cases have been created yet.</p>
    }
    else
    {
        <partial name="_CaseTable" model="Model" />
    }
</section>
